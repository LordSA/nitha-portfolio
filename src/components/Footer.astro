---
// Footer.astro
---

<footer class="footer" role="contentinfo">
  <div class="footer-divider"></div>
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="#hero" class="footer-logo" aria-label="Back to top">
        <span class="nav-logo-text"
          >N<span class="accent">·</span>S<span class="accent">·</span>V</span
        >
      </a>
      <p class="footer-tagline">Emerging Journalist · Storyteller · Kerala</p>
    </div>
    <div class="footer-right">
      <p class="footer-copy">
        © 2026 Shibili Aman TK. Built with professionalism and a lot of coffee.
      </p>
      <a
        href="#hero"
        class="back-top"
        id="back-top"
        data-cursor-hover
        aria-label="Back to top"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"></path></svg
        >
        <span>Back to top</span>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    padding: 2rem 0;
  }

  .footer-divider {
    width: 100%;
    height: 1px;
    background: var(--line-dim);
    margin-bottom: 2rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-logo .nav-logo-text {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--paper);
    letter-spacing: 0.05em;
  }

  .footer-logo .accent {
    color: var(--accent);
  }

  .footer-tagline {
    font-size: 13px;
    color: var(--muted);
    margin-top: 0.25rem;
    font-style: italic;
    font-family: var(--font-display);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .footer-copy {
    font-size: 13px;
    color: var(--muted);
  }

  .back-top {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    border: 1px solid var(--line-dim);
    padding: 0.4rem 0.9rem;
    border-radius: 100px;
    transition:
      color 0.3s,
      border-color 0.3s,
      background 0.3s;
  }

  .back-top:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-glow);
  }
</style>
