---
// Experience.astro

const experiences = [
  {
    id: 'mediaone',
    org: 'MediaOne TV',
    logo: 'M1',
    color: '#1B6CA8',
    role: 'Journalism Intern',
    type: 'Internship · On-site',
    period: 'Apr 2026 – Present',
    duration: '2 months',
    location: 'Kozhikode, Kerala',
    description: 'Working as a Journalism Intern at MediaOne TV — supporting news production, assisting in research and scripting, and gaining practical exposure to professional broadcast and editorial processes.',
    skills: ['News Writing', 'Voiceovers', 'Broadcast Production', 'Research & Scripting'],
    current: true,
  },
  {
    id: 'swantham-pt',
    org: 'Swantham Channel',
    logo: 'SW',
    color: '#C8913A',
    role: 'News Anchor',
    type: 'Part-time · On-site',
    period: 'Jun 2025 – Present',
    duration: '1 year',
    location: 'Nilambur, Kerala',
    description: 'Delivering news bulletins with clarity and credibility while actively contributing to live broadcast production and newsroom coordination at Swantham Channel.',
    skills: ['Voice Casting', 'News Writing', 'Live Broadcast', 'Newsroom Coordination'],
    current: true,
  },
  {
    id: 'swantham-intern',
    org: 'Swantham Channel',
    logo: 'SW',
    color: '#C8913A',
    role: 'News Anchor',
    type: 'Internship · On-site',
    period: 'Apr 2025 – May 2025',
    duration: '2 months',
    location: 'Nilambur, Kerala',
    description: 'Completed a one-month internship delivering news bulletins with clarity and confidence, gaining hands-on experience in newsroom operations, newsreading, and voiceover production.',
    skills: ['Newsreading', 'Voiceovers', 'Newsroom Operations'],
    current: false,
  },
];
---

<section id="experience" class="section experience-section" aria-label="Professional Experience">
  <!-- Background texture -->
  <div class="exp-bg" aria-hidden="true"></div>

  <div class="container">
    <!-- Section header -->
    <div class="section-header reveal-up" id="exp-header">
      <span class="label">Experience</span>
      <div class="divider"></div>
      <h2 class="headline">
        Newsrooms <em>I've</em><br/>walked into.
      </h2>
      <p class="body-lg" style="max-width: 480px; margin-top: 1rem;">
        From internships to live broadcasts — building real-world journalism skills across Kerala's media landscape.
      </p>
    </div>

    <!-- Timeline -->
    <div class="timeline" id="timeline">
      <!-- Animated vertical line -->
      <div class="timeline-track" aria-hidden="true">
        <div class="timeline-line" id="timeline-line"></div>
      </div>

      {experiences.map((exp, i) => (
        <article
          class={`timeline-item ${i % 2 === 0 ? 'left' : 'right'}`}
          id={`exp-${exp.id}`}
          data-index={i}
          aria-label={`${exp.role} at ${exp.org}`}
        >
          <!-- Timeline dot -->
          <div class="timeline-dot-wrap" aria-hidden="true">
            <div class="timeline-dot" style={`background: ${exp.color}`}>
              {exp.current && <div class="dot-pulse" style={`background: ${exp.color}`}></div>}
            </div>
          </div>

          <!-- Card -->
          <div class="exp-card" data-cursor-hover>
            <!-- Card header -->
            <div class="exp-card-top">
              <div class="exp-logo-wrap" style={`background: ${exp.color}18; border-color: ${exp.color}30`}>
                <span class="exp-logo-text" style={`color: ${exp.color}`}>{exp.logo}</span>
              </div>
              <div class="exp-meta">
                <p class="exp-org">{exp.org}</p>
                <p class="exp-type label" style="color: var(--muted); text-transform: none; font-size: 12px;">{exp.type}</p>
              </div>
              {exp.current && (
                <div class="exp-current-badge">
                  <span class="current-dot"></span>
                  <span class="label" style="font-size: 10px;">Current</span>
                </div>
              )}
            </div>

            <!-- Divider -->
            <div class="divider-full" style="margin: 1rem 0;"></div>

            <h3 class="exp-role">{exp.role}</h3>
            <div class="exp-period">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>{exp.period}</span>
              <span class="period-sep">·</span>
              <span style="color: var(--muted);">{exp.duration}</span>
            </div>
            <div class="exp-location">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{exp.location}</span>
            </div>

            <p class="exp-desc">{exp.description}</p>

            <div class="exp-skills">
              {exp.skills.map(skill => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.experience-section {
  background: var(--ink-2);
  position: relative;
}

.exp-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 80% 20%, rgba(27, 108, 168, 0.05) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 20% 80%, rgba(200, 145, 58, 0.04) 0%, transparent 60%);
  pointer-events: none;
}

/* Section header */
.section-header {
  margin-bottom: 5rem;
}

.section-header em {
  color: var(--accent);
  font-style: italic;
}

/* Timeline */
.timeline {
  position: relative;
  padding-left: 50%;
  display: flex;
  flex-direction: column;
  gap: 4rem;
}

.timeline-track {
  position: absolute;
  left: 50%;
  top: 0; bottom: 0;
  transform: translateX(-50%);
  width: 2px;
  background: var(--line-dim);
  overflow: hidden;
}

.timeline-line {
  width: 100%;
  height: 0%;
  background: linear-gradient(to bottom, var(--accent-2), var(--accent));
  transition: height 0.1s linear;
}

.timeline-item {
  position: relative;
  width: 48%;
  padding: 0 3rem;
  box-sizing: border-box;
}

.timeline-item.left {
  margin-left: -100%;
  padding-right: 4rem;
  padding-left: 0;
}

.timeline-item.right {
  margin-left: 2%;
  padding-left: 4rem;
  padding-right: 0;
}

/* Timeline dot */
.timeline-dot-wrap {
  position: absolute;
  right: -9px;
  top: 2rem;
  z-index: 2;
}

.timeline-item.right .timeline-dot-wrap {
  right: auto;
  left: -9px;
}

.timeline-dot {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 3px solid var(--ink-2);
  position: relative;
  z-index: 2;
}

.dot-pulse {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  opacity: 0.3;
  animation: dot-pulse-anim 2s ease-in-out infinite;
}

@keyframes dot-pulse-anim {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.8); opacity: 0; }
}

/* Card */
.exp-card {
  background: var(--ink);
  border: 1px solid var(--line-dim);
  border-radius: var(--radius-lg);
  padding: 2rem;
  transition: border-color 0.3s, transform 0.3s var(--ease-out), box-shadow 0.3s;
  position: relative;
  overflow: hidden;
}

.exp-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}

.exp-card:hover {
  border-color: var(--line);
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
}

.exp-card:hover::before { opacity: 1; }

.exp-card-top {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: 0;
}

.exp-logo-wrap {
  width: 48px;
  height: 48px;
  border-radius: var(--radius);
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.exp-logo-text {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
}

.exp-meta { flex: 1; }

.exp-org {
  font-weight: 600;
  color: var(--paper);
  margin-bottom: 0.15rem;
}

.exp-current-badge {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.25rem 0.6rem;
  background: rgba(74, 222, 128, 0.1);
  border: 1px solid rgba(74, 222, 128, 0.3);
  border-radius: 100px;
  flex-shrink: 0;
}

.current-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #4ade80;
  animation: dot-pulse-anim 2s ease-in-out infinite;
}

.exp-role {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 600;
  color: var(--paper);
  margin-bottom: 0.5rem;
}

.exp-period, .exp-location {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 13px;
  color: var(--muted);
  margin-bottom: 0.3rem;
}

.period-sep { color: var(--muted-2); }

.exp-desc {
  margin: 1rem 0;
  font-size: 15px;
  line-height: 1.7;
  color: var(--paper-dim);
}

.exp-skills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 1rem;
}

.skill-tag {
  padding: 0.25rem 0.7rem;
  background: var(--ink-2);
  border: 1px solid var(--line-dim);
  border-radius: 100px;
  font-size: 11px;
  font-weight: 500;
  color: var(--muted);
  letter-spacing: 0.04em;
}

/* Responsive */
@media (max-width: 768px) {
  .timeline {
    padding-left: 0;
  }

  .timeline-track {
    left: 20px;
  }

  .timeline-item.left,
  .timeline-item.right {
    width: 100%;
    margin-left: 0;
    padding-left: 60px;
    padding-right: 0;
  }

  .timeline-dot-wrap {
    left: 11px !important;
    right: auto !important;
  }
}
</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

// Animate timeline line with scroll
const timelineLine = document.getElementById('timeline-line')!;
const timeline = document.getElementById('timeline')!;

ScrollTrigger.create({
  trigger: timeline,
  start: 'top 70%',
  end: 'bottom 80%',
  scrub: 0.5,
  onUpdate: (self) => {
    timelineLine.style.height = `${self.progress * 100}%`;
  }
});

// Reveal section header
gsap.to('#exp-header', {
  opacity: 1,
  y: 0,
  duration: 1,
  ease: 'power3.out',
  scrollTrigger: {
    trigger: '#exp-header',
    start: 'top 85%',
    once: true,
  }
});

// Reveal each timeline item
document.querySelectorAll('.timeline-item').forEach((item, i) => {
  const isLeft = item.classList.contains('left');
  gsap.set(item, { opacity: 0, x: isLeft ? -60 : 60 });

  gsap.to(item, {
    opacity: 1,
    x: 0,
    duration: 0.9,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: item,
      start: 'top 85%',
      once: true,
    },
    delay: 0.1 * i,
  });
});
</script>
