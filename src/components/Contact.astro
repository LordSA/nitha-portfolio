---
// Contact.astro
---

<section id="contact" class="section contact-section" aria-label="Contact">
  <!-- Animated background -->
  <div class="contact-bg" aria-hidden="true">
    <div class="contact-orb orb-1"></div>
    <div class="contact-orb orb-2"></div>
  </div>

  <div class="container contact-inner">

    <!-- Big kinetic headline -->
    <div class="contact-headline-wrap" id="contact-headline-wrap">
      <div class="headline-overflow">
        <h2 class="display-1 contact-headline" id="contact-h1">Let's</h2>
      </div>
      <div class="headline-overflow">
        <h2 class="display-1 contact-headline contact-headline-stroke" id="contact-h2">Tell a</h2>
      </div>
      <div class="headline-overflow">
        <h2 class="display-1 contact-headline" id="contact-h3">Story.</h2>
      </div>
    </div>

    <!-- Right panel -->
    <div class="contact-panel" id="contact-panel">
      <div class="divider"></div>
      <p class="body-lg contact-desc">
        I'm open to journalism opportunities, collaborations, freelance assignments, and conversations about meaningful storytelling. Let's connect.
      </p>

      <!-- Contact cards -->
      <div class="contact-links">
        <a
          href="mailto:nithasharinvp@gmail.com"
          class="contact-card"
          id="contact-email"
          data-cursor-hover
          aria-label="Email Nitha Sharin VP"
        >
          <div class="contact-card-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 14 2 4"/></svg>
          </div>
          <div class="contact-card-info">
            <span class="label" style="font-size: 10px; color: var(--muted);">Email</span>
            <span class="contact-card-val">nithasharinvp@gmail.com</span>
          </div>
          <div class="contact-card-arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a
          href="https://www.linkedin.com/in/nithasharinvp"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
          id="contact-linkedin"
          data-cursor-hover
          aria-label="LinkedIn profile of Nitha Sharin VP"
        >
          <div class="contact-card-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z"/></svg>
          </div>
          <div class="contact-card-info">
            <span class="label" style="font-size: 10px; color: var(--muted);">LinkedIn</span>
            <span class="contact-card-val">in/nithasharinvp</span>
          </div>
          <div class="contact-card-arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <div class="contact-card contact-card-location">
          <div class="contact-card-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="contact-card-info">
            <span class="label" style="font-size: 10px; color: var(--muted);">Based in</span>
            <span class="contact-card-val">Kerala, India</span>
          </div>
          <div class="contact-card-badge label" style="font-size: 10px; padding: 0.2rem 0.6rem; background: var(--accent-glow); border: 1px solid var(--line); border-radius: 100px; color: var(--accent);">
            Open to work
          </div>
        </div>
      </div>

    </div>

  </div>

  <!-- Bottom press strip -->
  <div class="press-strip" aria-hidden="true">
    <div class="press-text">
      {Array.from({length: 8}).map(() => (
        <span>Journalism · Truth · Community · Stories</span>
      ))}
    </div>
  </div>

</section>

<style>
.contact-section {
  background: var(--ink);
  position: relative;
  overflow: hidden;
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.contact-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.contact-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
}

.orb-1 {
  width: 600px;
  height: 600px;
  background: rgba(200, 145, 58, 0.06);
  top: -100px;
  left: -100px;
  animation: float 8s ease-in-out infinite;
}

.orb-2 {
  width: 400px;
  height: 400px;
  background: rgba(27, 108, 168, 0.06);
  bottom: -50px;
  right: -50px;
  animation: float 10s ease-in-out infinite reverse;
}

.contact-inner {
  display: grid;
  grid-template-columns: 1fr 480px;
  gap: clamp(3rem, 6vw, 8rem);
  align-items: center;
  padding-top: 2rem;
  padding-bottom: 4rem;
  position: relative;
  z-index: var(--z-content);
}

/* Kinetic headline */
.contact-headline-wrap {
  overflow: hidden;
}

.headline-overflow {
  overflow: hidden;
}

.contact-headline {
  display: block;
  will-change: transform;
  transform: translateY(100%);
  color: var(--paper);
}

.contact-headline-stroke {
  color: transparent;
  -webkit-text-stroke: 1.5px var(--accent);
}

/* Panel */
.contact-panel {
  opacity: 0;
  transform: translateX(40px);
}

.contact-desc {
  margin: 1.5rem 0 2rem;
}

/* Contact cards */
.contact-links {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.contact-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.25rem 1.5rem;
  background: var(--ink-2);
  border: 1px solid var(--line-dim);
  border-radius: var(--radius-lg);
  transition: border-color 0.3s, transform 0.3s var(--ease-out), box-shadow 0.3s;
  text-decoration: none;
}

.contact-card:hover {
  border-color: var(--accent);
  transform: translateX(6px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
}

.contact-card-location { cursor: default; }
.contact-card-location:hover { transform: none; border-color: var(--line-dim); }

.contact-card-icon {
  width: 44px;
  height: 44px;
  border-radius: var(--radius);
  background: var(--accent-glow);
  border: 1px solid var(--line);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  flex-shrink: 0;
  transition: background 0.3s;
}

.contact-card:hover .contact-card-icon {
  background: var(--accent);
  color: var(--ink);
}

.contact-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.contact-card-val {
  font-size: 15px;
  font-weight: 500;
  color: var(--paper);
}

.contact-card-arrow {
  color: var(--muted);
  transition: transform 0.3s, color 0.3s;
}

.contact-card:hover .contact-card-arrow {
  transform: translateX(4px);
  color: var(--accent);
}

/* Press strip */
.press-strip {
  position: relative;
  border-top: 1px solid var(--line-dim);
  overflow: hidden;
  padding: 1rem 0;
  margin-top: auto;
}

.press-text {
  display: flex;
  gap: 0;
  width: max-content;
  animation: marquee 20s linear infinite;
  opacity: 0.2;
}

.press-text span {
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 400;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  padding: 0 3rem;
  color: var(--paper);
  white-space: nowrap;
}

@media (max-width: 900px) {
  .contact-inner {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
gsap.registerPlugin(ScrollTrigger);

// Kinetic headline slide in
gsap.to('.contact-headline', {
  y: '0%',
  duration: 1.2,
  ease: 'power4.out',
  stagger: 0.12,
  scrollTrigger: {
    trigger: '#contact-headline-wrap',
    start: 'top 80%',
    once: true,
  }
});

// Panel reveal
gsap.to('#contact-panel', {
  opacity: 1,
  x: 0,
  duration: 1,
  ease: 'power3.out',
  scrollTrigger: {
    trigger: '#contact-panel',
    start: 'top 80%',
    once: true,
  }
});
</script>
